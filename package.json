{
  "name": "contract-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite",
    "dev:backend": "convex dev",
    "build": "vite build",
    "lint": "eslint . --ignore-pattern convex/_generated --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p convex/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "auth:generate-keys": "node scripts/generateKeys.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.34.1",
    "@convex-dev/auth": "^0.0.43",
    "@convex-dev/react-query": "^0.0.0-alpha.3",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@react-email/components": "0.0.22",
    "@tanstack/react-form": "0.26.4",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-router": "^1.45.11",
    "@tanstack/zod-form-adapter": "^0.26.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "convex": "^1.22.0",
    "convex-helpers": "^0.1.50",
    "cookie": "^0.6.0",
    "docx-preview": "^0.3.7",
    "docxtemplater": "^3.55.4",
    "docxtemplater-image-module-free": "^1.1.1",
    "image-size": "^2.0.2",
    "lucide-react": "^0.416.0",
    "mammoth": "^1.11.0",
    "npm-run-all": "^4.1.5",
    "oslo": "^1.2.1",
    "pizzip": "^3.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "resend": "^6.9.2",
    "signature_pad": "^5.1.3",
    "stripe": "^16.6.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@tanstack/router-devtools": "^1.45.11",
    "@tanstack/router-plugin": "^1.45.8",
    "@types/node": "^20.19.31",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "jose": "^5.9.6",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^7.17.0",
    "vitest": "^4.0.18",
    "vite": "^5.3.4"
  }
}
